---
// Top navigation component for mobile and desktop
import logo from '@assets/favicons/MCB.Logo.svg';
import darkLogo from '@assets/images/darklogo.png';

// Get current URL to determine active state
const currentUrl = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-[var(--color-bg-base)] backdrop-blur-md dark:backdrop-blur-none border-0">
  <div class="max-w-7xl mx-auto px-3 sm:px-4">
    <div class="flex justify-between items-center py-2.5 sm:py-3 gap-2 sm:gap-3">
      <div class="flex items-center flex-1 min-w-0 gap-2 sm:gap-3">
      <!-- Heading - Show on all pages as clickable home link -->
      <h1 class="min-w-0">
        <a 
          href="/" 
          class="inline-block group transition-all duration-200 relative"
          aria-label="Home"
          title="Go to Home"
        >
          <img 
            src={logo.src} 
            alt="My Calorie Balance Diary" 
            class={`h-[60px] w-auto sm:h-12 md:h-16 lg:h-20 xl:h-24 object-contain block dark:hidden transition-all duration-200 ${
              currentUrl === '/' ? '' : 'group-hover:scale-110 group-hover:opacity-80 group-hover:brightness-110'
            }`}
          />
          <img 
            src={darkLogo.src} 
            alt="My Calorie Balance Diary" 
            class={`dark-logo h-[60px] w-auto sm:h-12 md:h-16 lg:h-20 xl:h-24 object-contain hidden dark:block transition-all duration-200 ${
              currentUrl === '/' ? '' : 'group-hover:scale-110 group-hover:opacity-80 group-hover:brightness-125'
            }`}
          />
        </a>
      </h1>

      </div>

      <div class="flex justify-end items-center gap-1 sm:gap-2 flex-shrink-0 min-w-0">

      <!-- Upgrade to Pro -->
      <a
        href="/pro/"
        class={`inline-flex items-center gap-1.5 flex-shrink-0 px-3 py-1.5 text-xs font-bold transition-all duration-200 rounded-lg group ${
          currentUrl.startsWith('/pro/')
            ? 'bg-blue-600 dark:bg-blue-500 text-white shadow-md'
            : 'bg-gradient-to-r from-blue-600 to-violet-600 text-white hover:from-blue-700 hover:to-violet-700 hover:shadow-md'
        }`}
        aria-label="Upgrade to Pro"
        title="Unlock premium features"
      >
        <svg
          class={`w-3.5 h-3.5 transition-all duration-200 ${
            currentUrl.startsWith('/pro/') ? 'scale-110' : 'group-hover:scale-110'
          }`}
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" />
        </svg>
        <span>Upgrade</span>
      </a>

      </div>
    </div>
  </div>
</nav>

<!-- Add padding to prevent content from being hidden behind the fixed top nav -->
<style>
  /* Add padding to the page when top nav is present */
  :global(body:has(.top-nav-present)) {
    padding-top: 80px;
  }
  
  /* Alternative approach for browsers that don't support :has() */
  :global(.top-nav-present) {
    padding-top: 80px;
  }
  
  /* Ensure proper spacing for mobile devices */
  @media (max-width: 768px) {
    :global(body:has(.top-nav-present) main) {
      margin-top: 80px;
    }
  }
  
  /* Remove white background from dark mode logo */
  :global(.dark img[src="/icon.svg"]) {
    background: transparent !important;
    background-color: transparent !important;
  }
  
  /* Ensure transparent logo displays correctly in dark mode */
  :global(.dark .dark-logo),
  :global(.dark img.dark-logo) {
    background: transparent !important;
    background-color: transparent !important;
    mix-blend-mode: normal;
    opacity: 1;
  }
  
  /* Target the logo container to ensure proper background */
  :global(.dark nav h1 a) {
    background: transparent !important;
  }
  
  /* Blue hover effect for logo - similar to other nav icons */
  :global(nav h1 a.group:hover img:not(.dark-logo)) {
    filter: brightness(1.15) saturate(1.3) hue-rotate(5deg);
    opacity: 0.85;
  }
  
  :global(nav h1 a.group:hover img.dark-logo) {
    filter: brightness(1.4) saturate(1.2);
    opacity: 0.85;
  }
  
  /* Blue tint overlay on hover */
  :global(nav h1 a.group:hover::after) {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(37, 99, 235, 0.1);
    border-radius: 0.5rem;
    pointer-events: none;
  }
</style>