---
// Top navigation component for mobile and desktop
import logo from '@assets/favicons/MCB.Logo.svg';
import darkLogo from '@assets/images/darklogo.png';

// Get current URL to determine active state
const currentUrl = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-[var(--color-bg-base)] backdrop-blur-md dark:backdrop-blur-none border-0">
  <div class="max-w-7xl mx-auto px-3 sm:px-4">
    <div class="flex justify-between items-center py-2.5 sm:py-3 gap-2 sm:gap-3">
      <div class="flex items-center flex-1 min-w-0 gap-2 sm:gap-3">
      <!-- Heading - Show on all pages as clickable home link -->
      <h1 class="min-w-0">
        <a 
          href="/" 
          class="inline-block group transition-all duration-200 relative"
          aria-label="Home"
          title="Go to Home"
        >
          <img
            src={logo.src}
            alt="My Calorie Balance Diary"
            class={`h-[72px] w-auto sm:h-[68px] md:h-[80px] lg:h-[96px] xl:h-[112px] object-contain block dark:hidden transition-all duration-200 logo-light ${
              currentUrl === '/' ? '' : 'group-hover:scale-105 group-hover:brightness-110'
            }`}
          />
          <img
            src={darkLogo.src}
            alt="My Calorie Balance Diary"
            class={`dark-logo h-[72px] w-auto sm:h-[68px] md:h-[80px] lg:h-[96px] xl:h-[112px] object-contain hidden dark:block transition-all duration-200 logo-dark ${
              currentUrl === '/' ? '' : 'group-hover:scale-105 group-hover:brightness-125'
            }`}
          />
        </a>
      </h1>

      </div>

      <div class="flex justify-end items-center gap-1 sm:gap-2 flex-shrink-0 min-w-0">

      <!-- Upgrade to Pro -->
      <a
        href="/pro/"
        class={`inline-flex items-center gap-1 flex-shrink-0 px-2.5 py-1 text-[11px] font-bold transition-all duration-200 rounded-lg group ${
          currentUrl.startsWith('/pro/')
            ? 'bg-blue-600 dark:bg-blue-500 text-white shadow-md'
            : 'bg-gradient-to-r from-blue-600 to-violet-600 text-white hover:from-blue-700 hover:to-violet-700 hover:shadow-md'
        }`}
        aria-label="Upgrade to Pro"
        title="Unlock premium features"
      >
        <svg
          class={`w-3 h-3 transition-all duration-200 ${
            currentUrl.startsWith('/pro/') ? 'scale-110' : 'group-hover:scale-110'
          }`}
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" />
        </svg>
        <span>Upgrade</span>
      </a>

      </div>
    </div>
  </div>
</nav>

<!-- Add padding to prevent content from being hidden behind the fixed top nav -->
<style>
  /* Offset fixed top nav — values match logo height + nav vertical padding at each breakpoint:
     mobile  72px logo + 2×10px py-2.5 = 92px  → 96px
     sm      68px logo + 2×12px py-3   = 92px  → 96px
     md      80px logo + 2×12px        = 104px → 108px
     lg      96px logo + 2×12px        = 120px → 124px
     xl     112px logo + 2×12px        = 136px → 140px  */
  :global(.top-nav-present) {
    padding-top: 96px;
  }
  @media (min-width: 768px) {
    :global(.top-nav-present) { padding-top: 108px; }
  }
  @media (min-width: 1024px) {
    :global(.top-nav-present) { padding-top: 124px; }
  }
  @media (min-width: 1280px) {
    :global(.top-nav-present) { padding-top: 140px; }
  }
  
  /* Remove white background from dark mode logo */
  :global(.dark img[src="/icon.svg"]) {
    background: transparent !important;
    background-color: transparent !important;
  }
  
  /* Ensure transparent logo displays correctly in dark mode */
  :global(.dark .dark-logo),
  :global(.dark img.dark-logo) {
    background: transparent !important;
    background-color: transparent !important;
    mix-blend-mode: normal;
    opacity: 1;
  }
  
  /* Target the logo container to ensure proper background */
  :global(.dark nav h1 a) {
    background: transparent !important;
  }
  
  /* Hover effect for logo */
  :global(nav h1 a.group:hover img.logo-light) {
    filter: brightness(1.08);
  }
  :global(nav h1 a.group:hover img.logo-dark) {
    filter: brightness(1.25);
  }
  
</style>