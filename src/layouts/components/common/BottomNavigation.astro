---
// Bottom navigation component for mobile and desktop

// Get current URL to determine active state
const currentUrl = Astro.url.pathname;
const insightsActive =
  currentUrl === '/insights/' ||
  currentUrl === '/insights' ||
  currentUrl.startsWith('/insights/');

const linkBase = 'flex flex-col items-center justify-center py-2 px-3 min-h-[60px] min-w-[60px] transition-all duration-200 group';
const activeLink = 'text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 rounded-lg';
const inactiveLink = 'text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400';
const iconBase = 'w-6 h-6 mb-1 transition-all duration-200';
const activeIcon = 'scale-110';
const inactiveIcon = 'group-hover:scale-110';
const labelBase = 'text-xs font-medium';
const activeLabel = 'text-blue-600 dark:text-blue-400';
---

<nav class="fixed bottom-0 left-0 right-0 z-50 bg-white dark:bg-[var(--color-bg-base)] shadow-lg">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex justify-around items-center py-2">

      <!-- Home -->
      <a
        href="/"
        class={`${linkBase} ${currentUrl === '/' ? activeLink : inactiveLink}`}
        aria-label="Home"
      >
        <svg
          class={`${iconBase} ${currentUrl === '/' ? activeIcon : inactiveIcon}`}
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        <span class={`${labelBase} ${currentUrl === '/' ? activeLabel : ''}`}>Home</span>
      </a>

      <!-- Gallery -->
      <a
        href="/gallery/"
        class={`${linkBase} ${currentUrl === '/gallery/' ? activeLink : inactiveLink}`}
        aria-label="Gallery"
      >
        <svg
          class={`${iconBase} ${currentUrl === '/gallery/' ? activeIcon : inactiveIcon}`}
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" />
        </svg>
        <span class={`${labelBase} ${currentUrl === '/gallery/' ? activeLabel : ''}`}>Gallery</span>
      </a>

      <!-- Tools -->
      <a
        href="/tools/"
        class={`${linkBase} ${currentUrl === '/tools/' ? activeLink : inactiveLink}`}
        aria-label="Tools"
      >
        <svg
          class={`${iconBase} ${currentUrl === '/tools/' ? activeIcon : inactiveIcon}`}
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />
        </svg>
        <span class={`${labelBase} ${currentUrl === '/tools/' ? activeLabel : ''}`}>Tools</span>
      </a>

      <!-- Insights -->
      <a
        href="/insights/"
        class={`${linkBase} ${insightsActive ? activeLink : inactiveLink}`}
        aria-label="Insights"
      >
        <svg
          class={`${iconBase} ${insightsActive ? activeIcon : inactiveIcon}`}
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
        </svg>
        <span class={`${labelBase} ${insightsActive ? activeLabel : ''}`}>Insights</span>
      </a>

      <!-- Settings -->
      <a
        href="/settings/"
        class={`${linkBase} ${currentUrl === '/settings/' ? activeLink : inactiveLink}`}
        aria-label="Settings"
      >
        <svg
          class={`${iconBase} ${currentUrl === '/settings/' ? activeIcon : inactiveIcon}`}
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class={`${labelBase} ${currentUrl === '/settings/' ? activeLabel : ''}`}>Settings</span>
      </a>

    </div>
  </div>
</nav>

<!-- Add padding to prevent content from being hidden behind the fixed bottom nav -->
<style>
  :global(body:has(.bottom-nav-present)) {
    padding-bottom: 80px;
  }
  :global(.bottom-nav-present) {
    padding-bottom: 80px;
  }
  @media (max-width: 320px) {
    .fixed.bottom-0 {
      padding-bottom: env(safe-area-inset-bottom);
    }
  }
  @media (max-width: 768px) {
    :global(body:has(.bottom-nav-present) main) {
      margin-bottom: 80px;
    }
  }
</style>
