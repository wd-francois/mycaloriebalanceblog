---
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import KilojouleConverterComponent from '../components/KilojouleConverter.jsx';
import PWAInstallPrompt from '../components/PWAInstallPrompt.jsx';
import OfflineIndicator from '../components/OfflineIndicator.jsx';
---

<Layout
  title={`Kilojoule Converter - ${siteConfig.title}`}
  description="Convert kilojoules to calories and calories to kilojoules. Easy-to-use energy unit converter for nutrition tracking."
  showBottomNav={true}
  wideContent={true}
  showTopNav={true}
  showFooter={false}
>
  <div class="w-full bg-white dark:bg-[var(--color-bg-base)]">
    <!-- Content -->
    <div class="w-full px-4 sm:px-6 py-6 sm:py-8 md:py-10">
      <div class="relative max-w-3xl mx-auto">
        <a href="/tools/" class="absolute top-4 right-4 z-10 p-2 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" title="Back to Tools" aria-label="Back to Tools">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </a>
        <KilojouleConverterComponent client:load />
      </div>
    </div>
  </div>
  
  <!-- PWA Components -->
  <PWAInstallPrompt client:load />
  <OfflineIndicator client:load />
</Layout>

