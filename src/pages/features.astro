---
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
---

<Layout
  title={`Features — ${siteConfig.title}`}
  description="Discover how My Calorie Balance helps you build healthier eating habits through simple, consistent food journaling — not obsessive calorie counting."
  showTopNav={true}
  showBottomNav={true}
  wideContent={true}
>

<!-- ─────────────────────────────────────────────────────────────────────────
     HERO
───────────────────────────────────────────────────────────────────────── -->
<section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-blue-950 to-indigo-900 text-white">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-blue-500/10 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full bg-indigo-500/10 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-blue-600/5 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Text -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-500/20 border border-blue-400/30 text-blue-300 text-xs font-semibold uppercase tracking-wider mb-6">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          Mindful · Simple · Effective
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight mb-6">
          Build better habits,<br />
          <span class="bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent">not a calorie obsession</span>
        </h1>

        <p class="text-lg sm:text-xl text-slate-300 leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
          My Calorie Balance is a food diary that helps you understand what you eat — without the anxiety of strict tracking. Log a meal in seconds, spot your patterns, and eat with more intention.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
          <a href="/" class="inline-flex items-center justify-center gap-2.5 px-7 py-4 bg-blue-500 hover:bg-blue-400 text-white font-bold rounded-2xl shadow-lg shadow-blue-500/30 hover:shadow-blue-400/40 transition-all duration-200 text-base">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            Start Logging Free
          </a>
          <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-2xl border border-white/20 transition-all duration-200 text-base">
            See how it works
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </a>
        </div>

        <!-- Social proof -->
        <div class="mt-10 flex items-center gap-6 justify-center lg:justify-start text-slate-400">
          <div class="text-center">
            <p class="text-2xl font-extrabold text-white">100%</p>
            <p class="text-xs">Free to use</p>
          </div>
          <div class="w-px h-10 bg-slate-700"></div>
          <div class="text-center">
            <p class="text-2xl font-extrabold text-white">Private</p>
            <p class="text-xs">Your data stays local</p>
          </div>
          <div class="w-px h-10 bg-slate-700"></div>
          <div class="text-center">
            <p class="text-2xl font-extrabold text-white">Offline</p>
            <p class="text-xs">Works without internet</p>
          </div>
        </div>
      </div>

      <!-- Hero phone mockup -->
      <div class="flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Glow -->
          <div class="absolute inset-0 -m-8 rounded-full bg-blue-500/20 blur-3xl"></div>
          <!-- Phone -->
          <div class="relative w-[280px] bg-slate-900 rounded-[2.75rem] ring-1 ring-white/10 shadow-2xl shadow-black/60 p-2.5">
            <div class="rounded-[2.25rem] overflow-hidden bg-white dark:bg-slate-900" style="height:580px;">
              <!-- Status bar -->
              <div class="flex items-center justify-between px-5 pt-3 pb-1 bg-gradient-to-br from-blue-50 via-white to-purple-50">
                <span class="text-[10px] font-semibold text-gray-600">9:41</span>
                <div class="w-20 h-4 bg-gray-900 rounded-full"></div>
                <div class="flex gap-1 items-center">
                  <svg class="w-3 h-3 text-gray-600" fill="currentColor" viewBox="0 0 24 24"><path d="M1.5 8.5a13 13 0 0121 0M5.5 12.5a8 8 0 0113 0M9.5 16.5a3 3 0 015 0M12 20h.01"/></svg>
                  <div class="flex gap-0.5 items-end h-3">
                    <div class="w-1 h-1 bg-gray-600 rounded-sm"></div>
                    <div class="w-1 h-1.5 bg-gray-600 rounded-sm"></div>
                    <div class="w-1 h-2 bg-gray-600 rounded-sm"></div>
                    <div class="w-1 h-3 bg-gray-600 rounded-sm"></div>
                  </div>
                </div>
              </div>
              <!-- App content -->
              <div class="px-4 pt-2 pb-3 bg-gradient-to-br from-blue-50 via-white to-purple-50">
                <div class="flex items-center justify-between mb-3">
                  <div>
                    <p class="text-xs text-gray-500 font-medium">Good morning ☀️</p>
                    <p class="text-lg font-extrabold text-gray-900">Sunday, Jun 14</p>
                  </div>
                  <div class="flex items-center gap-1.5 px-2.5 py-1 bg-orange-100 rounded-xl">
                    <span class="text-sm">🔥</span>
                    <span class="text-xs font-bold text-orange-700">7 day streak</span>
                  </div>
                </div>
                <!-- Calorie ring -->
                <div class="flex items-center gap-3 p-2.5 bg-white rounded-2xl shadow-sm border border-gray-100 mb-2.5">
                  <div class="relative w-14 h-14 flex-shrink-0">
                    <svg class="w-14 h-14 -rotate-90" viewBox="0 0 56 56">
                      <circle cx="28" cy="28" r="22" fill="none" stroke="#f3f4f6" stroke-width="6"/>
                      <circle cx="28" cy="28" r="22" fill="none" stroke="#3b82f6" stroke-width="6" stroke-dasharray="138.2" stroke-dashoffset="55" stroke-linecap="round"/>
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center">
                      <p class="text-xs font-black text-gray-800">60%</p>
                    </div>
                  </div>
                  <div class="flex-1">
                    <p class="text-xs text-gray-500 mb-0.5">Today's calories</p>
                    <p class="text-xl font-extrabold text-gray-900">1,240 <span class="text-sm font-normal text-gray-400">/ 2,000</span></p>
                    <div class="flex gap-2 mt-1">
                      <span class="text-[10px] font-semibold text-blue-600 bg-blue-50 px-1.5 py-0.5 rounded-md">P 82g</span>
                      <span class="text-[10px] font-semibold text-orange-600 bg-orange-50 px-1.5 py-0.5 rounded-md">C 140g</span>
                      <span class="text-[10px] font-semibold text-yellow-600 bg-yellow-50 px-1.5 py-0.5 rounded-md">F 38g</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Entry list -->
              <div class="px-4 pt-2 space-y-2">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Today's entries</p>
                {[
                  { emoji: '🥣', name: 'Oatmeal with berries', time: '7:30 AM', cal: '320 kcal', color: 'bg-orange-100 text-orange-700' },
                  { emoji: '☕', name: 'Flat white coffee', time: '8:15 AM', cal: '120 kcal', color: 'bg-orange-100 text-orange-700' },
                  { emoji: '🥗', name: 'Chicken Caesar salad', time: '12:30 PM', cal: '480 kcal', color: 'bg-orange-100 text-orange-700' },
                  { emoji: '🍎', name: 'Apple', time: '3:00 PM', cal: '80 kcal', color: 'bg-orange-100 text-orange-700' },
                  { emoji: '😴', name: '7h 40m sleep · Good', time: 'Last night', cal: '', color: 'bg-purple-100 text-purple-700' },
                ].map(item => (
                  <div class="flex items-center gap-2.5 p-2 bg-white rounded-xl border border-gray-100 shadow-sm">
                    <span class="text-lg flex-shrink-0">{item.emoji}</span>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-semibold text-gray-800 truncate">{item.name}</p>
                      <p class="text-[10px] text-gray-400">{item.time}</p>
                    </div>
                    {item.cal && <span class="text-[10px] font-bold text-gray-500 flex-shrink-0">{item.cal}</span>}
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────────
     PHILOSOPHY STRIP
───────────────────────────────────────────────────────────────────────── -->
<section class="bg-white dark:bg-[var(--color-bg-muted)] border-b border-gray-100 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      {[
        { icon: '🧘', title: 'Awareness, not anxiety', body: 'See your patterns clearly without micro-managing every macro.' },
        { icon: '⚡', title: 'Log in under 30 seconds', body: 'Your history auto-suggests meals. One tap to log what you already had.' },
        { icon: '🔒', title: 'Your data, your device', body: 'Everything stays on your phone. No account needed, no data sold.' },
      ].map(item => (
        <div class="flex flex-col items-center gap-3">
          <span class="text-4xl">{item.icon}</span>
          <h3 class="text-base font-bold text-gray-900 dark:text-white">{item.title}</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────────
     HOW IT WORKS
───────────────────────────────────────────────────────────────────────── -->
<section id="how-it-works" class="py-20 lg:py-28 bg-gray-50 dark:bg-[var(--color-bg-base)]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-sm font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-3">How it works</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white mb-4">
        Three steps to better eating habits
      </h2>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
        No onboarding surveys. No syncing accounts. Open the app and start.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 relative">
      <!-- Connector line (desktop only) -->
      <div class="hidden md:block absolute top-12 left-[calc(33.33%+1rem)] right-[calc(33.33%+1rem)] h-px bg-gradient-to-r from-blue-200 via-indigo-300 to-purple-200 dark:from-blue-800 dark:via-indigo-700 dark:to-purple-800"></div>

      {[
        {
          step: '1',
          color: 'bg-blue-500',
          title: 'Open and tap the date',
          body: 'The home screen shows today. Tap it to open your daily log — no navigation maze.',
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />`,
        },
        {
          step: '2',
          color: 'bg-indigo-500',
          title: 'Log meals, sleep, or movement',
          body: 'Type a food name — it autocompletes from your history. Add macros if you want them, or skip. Done.',
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />`,
        },
        {
          step: '3',
          color: 'bg-purple-500',
          title: 'Watch your patterns emerge',
          body: 'Insights reveal your weekly averages, best days, and trends — automatically.',
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />`,
        },
      ].map(item => (
        <div class="relative flex flex-col items-center text-center gap-4">
          <div class={`w-24 h-24 ${item.color} rounded-3xl flex items-center justify-center shadow-xl`}>
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" set:html={item.icon} />
          </div>
          <div>
            <p class="text-xs font-black text-gray-400 uppercase tracking-widest mb-1">Step {item.step}</p>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">{item.title}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{item.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────────
     FEATURE 1 — DAILY FOOD LOG
───────────────────────────────────────────────────────────────────────── -->
<section class="py-20 lg:py-28 bg-white dark:bg-[var(--color-bg-muted)] overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Phone mockup — meal form -->
      <div class="flex justify-center order-2 lg:order-1">
        <div class="relative">
          <div class="absolute -inset-8 bg-orange-50 dark:bg-orange-900/10 rounded-3xl blur-2xl"></div>
          <div class="relative w-[270px] bg-gray-900 rounded-[2.75rem] ring-1 ring-gray-700 shadow-2xl p-2.5">
            <div class="rounded-[2.25rem] overflow-hidden bg-white" style="height:560px;">
              <!-- Form header -->
              <div class="px-4 pt-4 pb-3 border-b border-gray-100 flex items-center gap-3">
                <div class="w-8 h-8 rounded-xl bg-orange-100 flex items-center justify-center">
                  <span class="text-sm">🍽️</span>
                </div>
                <div>
                  <p class="text-sm font-bold text-gray-900">Meal</p>
                  <p class="text-[10px] text-gray-400">Log food & macros</p>
                </div>
              </div>
              <div class="px-4 py-3 space-y-3">
                <!-- Name field with autocomplete suggestion -->
                <div>
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Meal Name *</p>
                  <div class="relative">
                    <div class="w-full px-3 py-2 rounded-xl border-2 border-blue-400 bg-white text-sm text-gray-800 font-medium">Chicken sa…</div>
                    <!-- Autocomplete dropdown -->
                    <div class="absolute top-full left-0 right-0 mt-1 bg-white rounded-xl border border-gray-100 shadow-xl z-10 overflow-hidden">
                      {['Chicken Caesar Salad', 'Chicken Salad Sandwich', 'Chicken Satay'].map((s, i) => (
                        <div class={`px-3 py-2 flex items-center gap-2.5 ${i === 0 ? 'bg-blue-50' : ''}`}>
                          <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                          <span class="text-xs text-gray-700 font-medium">{s}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
                <!-- Meal slot buttons -->
                <div class="mt-8">
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">Meal Slot</p>
                  <div class="flex flex-wrap gap-1.5">
                    {['Breakfast', 'AM Snack', 'Lunch', 'PM Snack', 'Dinner'].map((m, i) => (
                      <button class={`px-2.5 py-1 rounded-lg text-[10px] font-semibold ${i === 2 ? 'bg-orange-500 text-white' : 'bg-gray-100 text-gray-500'}`}>{m}</button>
                    ))}
                  </div>
                </div>
                <!-- Macros -->
                <div>
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5">Nutrition</p>
                  <div class="grid grid-cols-2 gap-2">
                    <div class="col-span-2 flex items-center gap-2 px-3 py-2 bg-gray-50 rounded-xl border border-gray-100">
                      <span class="text-[10px] font-bold text-gray-400 w-16">Calories</span>
                      <span class="text-sm font-bold text-gray-800 flex-1">480</span>
                      <span class="text-[10px] font-semibold text-gray-400">kcal</span>
                    </div>
                    {[['Protein', '38', 'g'], ['Carbs', '28', 'g'], ['Fats', '22', 'g']].map(([lbl, val, unit]) => (
                      <div class="flex items-center gap-2 px-3 py-2 bg-gray-50 rounded-xl border border-gray-100">
                        <span class="text-[10px] text-gray-400 flex-1">{lbl}</span>
                        <span class="text-xs font-bold text-gray-800">{val}{unit}</span>
                      </div>
                    ))}
                  </div>
                </div>
                <!-- Save button -->
                <button class="w-full py-2.5 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-xs font-bold">
                  Add Meal Entry
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div class="order-1 lg:order-2">
        <p class="text-sm font-bold text-orange-500 uppercase tracking-widest mb-3">Food logging</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white mb-5 leading-tight">
          Log a meal in under 30 seconds
        </h2>
        <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed mb-6">
          Start typing any food name and the app instantly suggests items from your personal history.
          Calories and macros auto-fill from your last log. No barcode scanner faff, no waiting for a database.
        </p>
        <ul class="space-y-3">
          {[
            'Autocomplete pulls from your own meal history first',
            'Add calories, protein, carbs, fats — or skip them all',
            'Assign to Breakfast, Lunch, Dinner, or Snack slots',
            'Advanced fields (fibre, other nutrients) collapse out of the way',
            'Notes field for anything extra — "rushed lunch", "restaurant portion"',
          ].map(item => (
            <li class="flex items-start gap-3 text-sm text-gray-600 dark:text-gray-400">
              <div class="w-5 h-5 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-orange-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              {item}
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────────────────────────────────
     FEATURE 2 — INSIGHTS
───────────────────────────────────────────────────────────────────────── -->
<section class="py-20 lg:py-28 bg-gray-50 dark:bg-[var(--color-bg-base)] overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Text -->
      <div>
        <p class="text-sm font-bold text-indigo-500 uppercase tracking-widest mb-3">Smart insights</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white mb-5 leading-tight">
          See your patterns, not just your numbers
        </h2>
        <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed mb-6">
          Most apps give you a number at the end of the day. My Calorie Balance shows you your
          <em>patterns</em> — the weekly trends, your best days, where you consistently go over,
          and how sleep affects your eating.
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {[
            { icon: '📈', title: 'Weekly calorie trends', body: 'See your 7-day rolling average to understand your real intake.' },
            { icon: '🥩', title: 'Macro balance', body: 'Protein, carbs, and fats over time — are you hitting your targets?' },
            { icon: '😴', title: 'Sleep & hunger link', body: 'Discover how poor sleep drives poor eating choices.' },
            { icon: '📅', title: 'Best & worst days', body: 'Identify which days of the week you struggle most.' },
          ].map(item => (
            <div class="p-4 bg-white dark:bg-[var(--color-bg-muted)] rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm">
              <span class="text-2xl block mb-2">{item.icon}</span>
              <h4 class="text-sm font-bold text-gray-800 dark:text-white mb-1">{item.title}</h4>
              <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Phone mockup — insights -->
      <div class="flex justify-center">
        <div class="relative">
          <div class="absolute -inset-8 bg-indigo-50 dark:bg-indigo-900/10 rounded-3xl blur-2xl"></div>
          <div class="relative w-[270px] bg-gray-900 rounded-[2.75rem] ring-1 ring-gray-700 shadow-2xl p-2.5">
            <div class="rounded-[2.25rem] overflow-hidden bg-white" style="height:560px; background: #f9fafb;">
              <!-- Header -->
              <div class="px-4 pt-4 pb-2 bg-white border-b border-gray-100">
                <p class="text-[10px] text-gray-400 font-medium">Last 7 days</p>
                <p class="text-lg font-extrabold text-gray-900">Your Insights</p>
              </div>
              <div class="px-4 py-3 space-y-3 overflow-hidden">
                <!-- Calorie bar chart -->
