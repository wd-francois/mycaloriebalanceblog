---
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import DailyEntries from '../components/DailyEntries.jsx';

// Get date from URL parameter
const dateParam = Astro.url.searchParams.get('date');
const date = dateParam || new Date().toISOString().split('T')[0];
---

<Layout
  title={`Daily Entries - ${siteConfig.title}`}
  description={`Browse all logged meals, workouts, sleep, and measurements for any day - ${siteConfig.title}`}
  wideContent={true}
  showBottomNav={true}
  showTopNav={true}
  showFooter={false}
>
  <DailyEntries client:load date={date} />
</Layout>

