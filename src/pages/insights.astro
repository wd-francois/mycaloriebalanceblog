---
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import PWAInstallPrompt from '../components/PWAInstallPrompt.jsx';
import OfflineIndicator from '../components/OfflineIndicator.jsx';
---

<Layout
  title="Insights - My Calorie Balance"
  description={"View data-driven insights and trends - " + siteConfig.title}
  showBottomNav={true}
  wideContent={true}
  showTopNav={true}
  showFooter={false}
>
  <main class="insights-page w-full bg-gray-50 dark:bg-[var(--color-bg-base)] flex flex-col min-h-screen overflow-y-auto" style="touch-action: pan-y; -webkit-overflow-scrolling: touch;">
    <section class="flex-1 flex items-center justify-center px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <div class="w-full max-w-4xl">
        <div class="mb-6 text-center">
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white">Insights</h1>
          <p class="mt-2 text-base sm:text-lg text-gray-600 dark:text-gray-300">
            Snapshot of your health data from Health Statistics.
          </p>
        </div>

        <div class="bg-white dark:bg-[var(--color-bg-muted)] border border-gray-200 dark:border-gray-700 rounded-3xl shadow-lg p-5 sm:p-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
            <a href="/insights/calories/" class="insight-card insight-card-link block no-underline text-inherit rounded-2xl">
              <h2 class="insight-title text-blue-700 dark:text-blue-300">Calories</h2>
              <p class="insight-value text-blue-600 dark:text-blue-400" id="insight-calories-main">-</p>
              <p class="insight-subtext" id="insight-calories-sub">Loading...</p>
              <p class="mt-3 text-xs font-semibold text-blue-600 dark:text-blue-400">Open →</p>
            </a>

            <a href="/insights/exercise/" class="insight-card insight-card-link block no-underline text-inherit rounded-2xl">
              <h2 class="insight-title text-orange-700 dark:text-orange-300">Exercise</h2>
              <p class="insight-value text-orange-600 dark:text-orange-400" id="insight-exercise-main">-</p>
              <p class="insight-subtext" id="insight-exercise-sub">Loading...</p>
              <p class="mt-3 text-xs font-semibold text-orange-600 dark:text-orange-400">Open →</p>
            </a>

            <a href="/insights/sleep/" class="insight-card insight-card-link block no-underline text-inherit rounded-2xl">
              <h2 class="insight-title text-purple-700 dark:text-purple-300">Sleep</h2>
              <p class="insight-value text-purple-600 dark:text-purple-400" id="insight-sleep-main">-</p>
              <p class="insight-subtext" id="insight-sleep-sub">Loading...</p>
              <p class="mt-3 text-xs font-semibold text-purple-600 dark:text-purple-400">Open →</p>
            </a>

            <a href="/insights/measurements/" class="insight-card insight-card-link block no-underline text-inherit rounded-2xl">
              <h2 class="insight-title text-green-700 dark:text-green-300">Measurements</h2>
              <p class="insight-value text-green-600 dark:text-green-400" id="insight-weight-main">-</p>
              <p class="insight-subtext" id="insight-weight-sub">Loading...</p>
              <p class="mt-3 text-xs font-semibold text-green-600 dark:text-green-400">Open →</p>
            </a>
          </div>
        </div>

        <div class="mt-6 space-y-5">
          <div class="bg-white dark:bg-[var(--color-bg-muted)] border border-gray-200 dark:border-gray-700 rounded-3xl shadow-lg p-5 sm:p-6">
            <h2 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white">Progress visuals</h2>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">
              Track logging streaks, longer-term trends, and how sleep aligns with calorie intake.
            </p>

            <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3">
              <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/30 p-3">
                <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Current streak</p>
                <p class="mt-1 text-2xl font-extrabold text-gray-900 dark:text-white" id="insight-streak-current">-</p>
              </div>
              <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/30 p-3">
                <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Best streak</p>
                <p class="mt-1 text-2xl font-extrabold text-gray-900 dark:text-white" id="insight-streak-best">-</p>
              </div>
              <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/30 p-3">
                <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Total logged days</p>
                <p class="mt-1 text-2xl font-extrabold text-gray-900 dark:text-white" id="insight-streak-total">-</p>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-[var(--color-bg-muted)] border border-gray-200 dark:border-gray-700 rounded-3xl shadow-lg p-5 sm:p-6">
            <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
              <h2 class="text-base sm:text-lg font-bold text-gray-900 dark:text-white">Calories & sleep trend</h2>
              <div id="insight-hub-trend-period-wrap" class="inline-flex rounded-xl border border-gray-200 dark:border-gray-700 p-1 bg-gray-50 dark:bg-gray-900/30" role="group" aria-label="Trend period">
                <button type="button" data-hub-trend-period="weekly" class="px-3 py-1.5 rounded-lg text-sm font-semibold bg-blue-600 text-white dark:bg-blue-500" aria-pressed="true">Weekly</button>
                <button type="button" data-hub-trend-period="monthly" class="px-3 py-1.5 rounded-lg text-sm font-semibold text-gray-700 dark:text-gray-200" aria-pressed="false">Monthly</button>
              </div>
            </div>
            <div id="insight-hub-trend-wrap" class="relative h-60 sm:h-72 w-full min-h-[14rem]">
              <canvas id="insight-hub-trend-chart" aria-label="Weekly or monthly trend chart"></canvas>
            </div>
            <p id="insight-hub-trend-empty" class="hidden text-sm text-center text-gray-500 dark:text-gray-400 py-8">
              Not enough calorie or sleep data yet to draw a trend.
            </p>
          </div>

          <div class="bg-white dark:bg-[var(--color-bg-muted)] border border-gray-200 dark:border-gray-700 rounded-3xl shadow-lg p-5 sm:p-6">
            <h2 class="text-base sm:text-lg font-bold text-gray-900 dark:text-white mb-3">Sleep vs calories correlation</h2>
            <div id="insight-hub-correlation-wrap" class="relative h-60 sm:h-72 w-full min-h-[14rem]">
              <canvas id="insight-hub-correlation-chart" aria-label="Sleep and calories correlation"></canvas>
            </div>
            <p id="insight-hub-correlation-empty" class="hidden text-sm text-center text-gray-500 dark:text-gray-400 py-8">
              Need days with both sleep and meal logs to show correlation.
            </p>
            <p id="insight-hub-correlation-summary" class="mt-3 text-sm text-gray-600 dark:text-gray-300">Loading...</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <PWAInstallPrompt client:load />
  <OfflineIndicator client:load />
</Layout>

<script>
  import { InsightsDashboard } from '../scripts/insightsDashboard.js';

  async function bootInsightsHub() {
    const dash = new InsightsDashboard();
    await dash.init();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      void bootInsightsHub();
    });
  } else {
    void bootInsightsHub();
  }
</script>

<style>
  .insight-card {
    border: 1px solid rgb(229 231 235);
    border-radius: 1rem;
    padding: 1rem;
    background: #fff;
    box-shadow: 0 4px 12px rgba(15, 23, 42, 0.04);
  }

  .insight-card-link {
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .insight-card-link:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
    border-color: rgb(59 130 246 / 0.35);
  }

  .insight-card-link:focus-visible {
    outline: 2px solid rgb(59 130 246);
    outline-offset: 2px;
  }

  :global(.dark) .insight-card {
    border-color: rgb(55 65 81);
    background: rgb(17 24 39 / 0.55);
    box-shadow: none;
  }

  .insight-title {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
  }

  .insight-value {
    font-size: 1.7rem;
    font-weight: 800;
    line-height: 1.2;
    margin: 0;
  }

  .insight-subtext {
    margin-top: 0.35rem;
    font-size: 0.82rem;
    color: rgb(75 85 99);
  }

  :global(.dark) .insight-subtext {
    color: rgb(156 163 175);
  }
</style>
