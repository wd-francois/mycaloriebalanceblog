---
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import PWAInstallPrompt from '../components/PWAInstallPrompt.jsx';
import OfflineIndicator from '../components/OfflineIndicator.jsx';

/** Hub summary cards — IDs must stay in sync with `insightsDashboard.js` / charts. */
const insightCards = [
  {
    title: 'Calories',
    href: '/insights/calories/',
    accent: 'bg-blue-500',
    mainId: 'insight-calories-main',
    subId: 'insight-calories-sub',
    valueClass: 'text-blue-600 dark:text-blue-400',
    ctaClass: 'text-blue-600 dark:text-blue-400',
  },
  {
    title: 'Exercise',
    href: '/insights/exercise/',
    accent: 'bg-orange-500',
    mainId: 'insight-exercise-main',
    subId: 'insight-exercise-sub',
    valueClass: 'text-orange-600 dark:text-orange-400',
    ctaClass: 'text-orange-600 dark:text-orange-400',
  },
  {
    title: 'Sleep',
    href: '/insights/sleep/',
    accent: 'bg-purple-500',
    mainId: 'insight-sleep-main',
    subId: 'insight-sleep-sub',
    valueClass: 'text-purple-600 dark:text-purple-400',
    ctaClass: 'text-purple-600 dark:text-purple-400',
  },
  {
    title: 'Measurements',
    href: '/insights/measurements/',
    accent: 'bg-green-500',
    mainId: 'insight-weight-main',
    subId: 'insight-weight-sub',
    valueClass: 'text-green-600 dark:text-green-400',
    ctaClass: 'text-green-600 dark:text-green-400',
  },
] as const;

const pageDescription = `View data-driven insights and trends - ${siteConfig.title}`;
---

<Layout
  title="Insights - My Calorie Balance"
  description={pageDescription}
  showBottomNav={true}
  wideContent={true}
  showTopNav={true}
  showFooter={false}
>
  <main class="scrollable-app-main w-full bg-white dark:bg-[var(--color-bg-base)] min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-6 sm:py-8 pb-24">

      <!-- Page header -->
      <div class="mb-6">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">Insights</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          A snapshot of your logged health data.
        </p>
      </div>

      <!-- 4 category cards -->
      <div class="grid grid-cols-2 gap-3 sm:gap-4 mb-6">
        {insightCards.map((card) => (
          <a
            href={card.href}
            class="group flex flex-col rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-[var(--color-bg-muted)] p-4 sm:p-5 hover:border-blue-300 dark:hover:border-blue-600 hover:shadow-md transition-all duration-200 no-underline"
          >
            <div class="flex items-center gap-2 mb-3">
              <span class={`w-2 h-5 rounded-full flex-shrink-0 ${card.accent}`}></span>
              <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">{card.title}</span>
            </div>
            <p class={`text-xl sm:text-2xl font-extrabold leading-tight ${card.valueClass}`} id={card.mainId}>—</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 flex-1" id={card.subId}>Loading…</p>
            <p class={`mt-3 text-xs font-semibold ${card.ctaClass}`}>Open →</p>
          </a>
        ))}
      </div>

      <!-- Streaks -->
      <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-[var(--color-bg-muted)] p-4 sm:p-5 mb-4">
        <h2 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wide mb-3">Logging streaks</h2>
        <div class="grid grid-cols-3 gap-3">
          <div class="rounded-xl border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/30 px-3 py-3 text-center">
            <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Current</p>
            <p class="text-2xl font-extrabold text-gray-900 dark:text-white" id="insight-streak-current">—</p>
          </div>
          <div class="rounded-xl border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/30 px-3 py-3 text-center">
            <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Best</p>
            <p class="text-2xl font-extrabold text-gray-900 dark:text-white" id="insight-streak-best">—</p>
          </div>
          <div class="rounded-xl border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/30 px-3 py-3 text-center">
            <p class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1">Total days</p>
            <p class="text-2xl font-extrabold text-gray-900 dark:text-white" id="insight-streak-total">—</p>
          </div>
        </div>
      </div>

      <!-- Calories & sleep trend -->
      <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-[var(--color-bg-muted)] p-4 sm:p-5 mb-4">
        <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
          <h2 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wide">Calories & sleep trend</h2>
          <div id="insight-hub-trend-period-wrap" class="inline-flex rounded-xl border border-gray-200 dark:border-gray-700 p-1 bg-gray-50 dark:bg-gray-900/30" role="group" aria-label="Trend period">
            <button type="button" data-hub-trend-period="weekly" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-blue-600 text-white dark:bg-blue-500" aria-pressed="true">Weekly</button>
            <button type="button" data-hub-trend-period="monthly" class="px-3 py-1.5 rounded-lg text-xs font-semibold text-gray-600 dark:text-gray-300" aria-pressed="false">Monthly</button>
          </div>
        </div>
        <div id="insight-hub-trend-wrap" class="relative h-56 sm:h-64 w-full">
          <canvas id="insight-hub-trend-chart" aria-label="Weekly or monthly trend chart"></canvas>
        </div>
        <p id="insight-hub-trend-empty" class="hidden text-sm text-center text-gray-500 dark:text-gray-400 py-8">
          Not enough calorie or sleep data yet to draw a trend.
        </p>
      </div>

      <!-- Sleep vs calories correlation -->
      <div class="rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-[var(--color-bg-muted)] p-4 sm:p-5">
        <h2 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wide mb-4">Sleep vs calories correlation</h2>
        <div id="insight-hub-correlation-wrap" class="relative h-56 sm:h-64 w-full">
          <canvas id="insight-hub-correlation-chart" aria-label="Sleep and calories correlation"></canvas>
        </div>
        <p id="insight-hub-correlation-empty" class="hidden text-sm text-center text-gray-500 dark:text-gray-400 py-8">
          Need days with both sleep and meal logs to show correlation.
        </p>
        <p id="insight-hub-correlation-summary" class="mt-3 text-sm text-gray-500 dark:text-gray-400">Loading…</p>
      </div>

    </div>
  </main>

  <PWAInstallPrompt client:load />
  <OfflineIndicator client:load />
</Layout>

<script>
  import { InsightsDashboard } from '../scripts/insightsDashboard.js';

  async function bootInsightsHub() {
    try {
      const dash = new InsightsDashboard();
      await dash.init();
    } catch (error) {
      console.error('[Insights] Dashboard init failed:', error);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      void bootInsightsHub();
    }, { once: true });
  } else {
    void bootInsightsHub();
  }
</script>
