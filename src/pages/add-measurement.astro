---
import Layout from '@layouts/Layout.astro';
import AddMeasurementsFormPage from '../components/AddMeasurementsFormPage.jsx';
import { siteConfig } from '@config/site';
import PWAInstallPrompt from '../components/PWAInstallPrompt.jsx';
import OfflineIndicator from '../components/OfflineIndicator.jsx';
---

<Layout
  title="Add Measurements - " + siteConfig.title
  description="Log body measurements - " + siteConfig.title
  wideContent={true}
  showBottomNav={true}
  showFooter={false}
  showHeader={false}
  showTopNav={true}
>
  <main class="add-measurement-page add-measurement-page-root w-full bg-gray-50 dark:bg-[var(--color-bg-base)] flex flex-col min-h-screen overflow-y-auto text-gray-900 dark:text-gray-100">
    <div class="add-measurement-page-inner flex-1 pt-24 pb-8 sm:pt-28 sm:pb-12 lg:pb-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <AddMeasurementsFormPage client:load />
      </div>
    </div>
  </main>

  <PWAInstallPrompt client:load />
  <OfflineIndicator client:load />

  <style>
    .dark .add-measurement-page {
      background: var(--color-bg-base);
      color: #e5e7eb;
    }
    .add-measurement-page {
      background: #f9fafb;
    }
    .add-measurement-page-inner {
      padding-top: 6rem;
    }
    @media (min-width: 640px) {
      .add-measurement-page-inner {
        padding-top: 7rem;
      }
    }
  </style>
</Layout>
